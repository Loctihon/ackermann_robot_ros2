<joint name="right_steering_to_base_link" type="revolute">
  <origin xyz="0.10312 -0.0505 0.0351" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="right_steering_1"/>
  <axis xyz="0.0 0.0 1.0"/>
  <limit lower="-0.785" upper="0.785" effort="200.0" velocity="10.0"/>
</joint>

<joint name="left_steering_to_base_link" type="revolute">
  <origin xyz="0.10312 0.0505 0.0351" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="left_steering_1"/>
  <axis xyz="0.0 0.0 1.0"/>
  <limit lower="-0.785" upper="0.785" effort="200.0" velocity="10.0"/>
</joint>

<joint name="left_rear_wheel_to_base_link" type="continuous">
  <origin xyz="-0.097623 0.083 0.0351" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="left_rear_wheel_1"/>
  <axis xyz="0.0 1.0 0.0"/> </joint>

<joint name="right_rear_wheel_to_base_link" type="continuous">
  <origin xyz="-0.098035 -0.083 0.0351" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="right_rear_wheel_1"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

<joint name="right_front_wheel_to_right_steering" type="continuous">
  <origin xyz="-0.00307 -0.032322 0.0" rpy="0 0 0"/>
  <parent link="right_steering_1"/>
  <child link="right_front_wheel_1"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

<joint name="left_front_wheel_to_left_steering" type="continuous">
  <origin xyz="-0.00307 0.032322 0.0" rpy="0 0 0"/>
  <parent link="left_steering_1"/>
  <child link="left_front_wheel_1"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

</robot>