<xacro:include filename="$(find robot_2_description)/urdf/camera.xacro" />

<link name="base_link">
  <inertial>
    <origin xyz="-0.030778695710215853 -0.00017187958403205029 0.0780034263273014" rpy="0 0 0"/>
    <mass value="6.148868144226647"/>
    <inertia ixx="0.012471" iyy="0.038142" izz="0.040818" ixy="-6.8e-05" iyz="-2e-05" ixz="0.007561"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 3.141592653589793"/>
    <geometry>
      <mesh filename="file://$(find robot_2_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 3.141592653589793"/>
    <geometry>
      <mesh filename="file://$(find robot_2_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

