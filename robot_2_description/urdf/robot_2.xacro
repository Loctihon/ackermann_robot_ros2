<?xml version="1.0" ?>
<robot name="robot_2" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find robot_2_description)/urdf/materials.xacro" />
<xacro:include filename="$(find robot_2_description)/urdf/robot_2.trans" />
